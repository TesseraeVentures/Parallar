# Parallar — TESTNET ONLY. Copy to .env (gitignored) and fill.
# NO REAL KEYS. All accounts are friendbot-funded testnet accounts.

# --- Stellar network (testnet) ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# --- Keys (testnet secret seeds, S...; fund via friendbot) ---
ADMIN_SECRET=
DEPLOYER_SECRET=

# --- RISC Zero proving path (Sprint 0 Spike 1 decision) ---
# local  = STARK -> Groth16 wrap via x86 Docker (arm64 host uses Rosetta; slow)
# remote = remote/x86 prover (pre-authorized fallback; may need an account/key)
RISC0_PROVER=local
REMOTE_PROVER_URL=
REMOTE_PROVER_API_KEY=
